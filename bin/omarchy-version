#!/bin/bash

OMARCHY_PATH=${OMARCHY_PATH:-$HOME/.local/share/omarchy}

# Get branch name
BRANCH=$(git -C "$OMARCHY_PATH" branch --show-current)

# Get commit hash (short)
HASH=$(git -C "$OMARCHY_PATH" rev-parse --short HEAD)

# Get tag if available, otherwise use commit hash
VERSION=$(git -C "$OMARCHY_PATH" describe --tags 2>/dev/null || echo "$HASH")

# Get modified files (limit to avoid overly long names)
MODIFIED_FILES=$(git -C "$OMARCHY_PATH" diff --name-only HEAD | head -5 | tr '\n' ',' | sed 's/,$//')

# Build description
DESC="$BRANCH@$HASH"
if [[ -n "$MODIFIED_FILES" ]]; then
    DESC="$DESC (modified: $MODIFIED_FILES)"
fi

echo "$DESC"
