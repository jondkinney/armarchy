show_update_menu() {
  case $(menu "Update" "Ьцђ Omarchy\nз░ћФ  Channel\nЬўЋ  Config\nз░Иї  Extra Themes\nЬ«б  Process\nз░ЄЁ  Hardware\nЬЕИ  Firmware\nЬгЉ  Password\nЬгЂ  Timezone\nЬјЃ  Time") in
