show_update_menu() {
  case $(menu "Update" "оӨҖ Omarchy\nу°”«  Channel\nоҳ•  Config\nу°ёҢ  Extra Themes\nо®ў  Process\nу°Ү…  Hardware\nо©ё  Firmware\nо¬‘  Password\nо¬Ғ  Timezone\nоҺғ  Time") in
