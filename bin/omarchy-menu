  case $(menu "Use default config" "пҚҷ  Hyprland\nпҚҷ  Hypridle\nпҚҷ  Hyprlock\nпҚҷ  Hyprsunset\nуұЈҙ  Plymouth\nпҚқ  Swayosd\nу°Ң§  Walker\nу°Қң  Waybar") in
