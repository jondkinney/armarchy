  esac
}

show_update_channel_menu() {
  case $(menu "Update channel" "рҹҹў Stable\nрҹҹЎ Edge\nрҹ”ҙ Dev") in
  *Stable*) present_terminal "omarchy-channel-set stable" ;;
  *Edge*) present_terminal "omarchy-channel-set edge" ;;
  *Dev*) present_terminal "omarchy-channel-set dev" ;;
  *) show_update_menu ;;
  esac
}
show_update_process_menu() {
  case $(menu "Restart" "пҚҷ  Hypridle\nпҚҷ  Hyprsunset\nпҚқ  Swayosd\nу°Ң§  Walker\nу°Қң  Waybar") in
